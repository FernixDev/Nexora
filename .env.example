# Copia este archivo como .env.local y rellena tus propios valores.
# Nunca subas el archivo .env.local real al repositorio.

# --- Supabase ---
# Project URL: panel de Supabase > Project Settings > API.
VITE_SUPABASE_URL=
# Publishable key (clave pública, segura para el frontend).
# Nunca uses aquí la service_role ni ninguna clave secreta.
VITE_SUPABASE_PUBLISHABLE_KEY=
